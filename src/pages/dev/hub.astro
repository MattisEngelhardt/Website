---
// Dev-only spike for the Main-Lobby (Workstream A).
// The living sea of fog as a navigable gallery: pan with the mouse, hover a
// plate to wipe the brushwork clear + lift its placard, click to dolly through
// the frame. Live FPS overlay so the honest frame rate can be judged on a real
// GPU. Noindex, sitemap-filtered.
// Query: ?hour=19.5  ?fov=55  ?yaw=0.46  ?nav (actually navigate on dolly)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="data:," />
    <title>dev/hub — Main-Lobby spike</title>
    <style>
      html, body { margin: 0; height: 100%; background: #11141f; overflow: hidden; }
      canvas { display: block; width: 100%; height: 100%; }
      #hud {
        position: fixed; left: 12px; top: 10px; z-index: 10;
        color: #ffe6c0; font: 13px/1.5 monospace;
        text-shadow: 0 1px 2px #000; white-space: pre; pointer-events: none;
      }

      /* the gallery placards — a museum placard under each plate, lifting on
         hover. Positioned per frame from the projected plate anchor. */
      #placards { position: fixed; inset: 0; z-index: 5; pointer-events: none; }
      .placard {
        position: absolute; left: 0; top: 0;
        transform: translate3d(-50%, 0, 0);
        text-align: center; color: #f7f1e6;
        opacity: 0; transition: opacity 320ms ease, filter 320ms ease;
        will-change: transform, opacity;
        /* a soft museum-card backplate so the text reads against any fog */
        padding: 0.5em 1.1em 0.65em;
        border-radius: 2px;
        background: linear-gradient(180deg,
          color-mix(in oklab, #1a1422 78%, transparent),
          color-mix(in oklab, #1a1422 58%, transparent));
        box-shadow: 0 6px 26px rgba(8, 6, 12, 0.4);
        backdrop-filter: blur(3px);
        border-top: 1px solid color-mix(in oklab, #ffce86 40%, transparent);
        text-shadow: 0 1px 3px rgba(8, 6, 12, 0.85);
      }
      .placard .num {
        font: 600 11px/1 monospace; letter-spacing: 0.24em;
        color: #ffce86; opacity: 0.9;
      }
      .placard .name {
        font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
        font-variation-settings: 'opsz' 72, 'SOFT' 0, 'WONK' 1;
        font-weight: 480; margin: 0.4em 0 0.15em;
        font-size: clamp(1.25rem, 2.6vw, 2.05rem); line-height: 1.05;
      }
      .placard .rule {
        width: 2.4em; height: 1px; margin: 0.5em auto;
        background: linear-gradient(90deg, transparent, #ffce86, transparent);
        opacity: 0.8;
      }
      .placard .line {
        font: italic 400 0.9rem/1.3 'Fraunces Variable', 'Fraunces', Georgia, serif;
        opacity: 0.9; letter-spacing: 0.01em;
      }
      .placard.is-hovered {
        opacity: 1 !important;
        background: linear-gradient(180deg,
          color-mix(in oklab, #1a1422 90%, transparent),
          color-mix(in oklab, #1a1422 72%, transparent));
      }

      #hint {
        position: fixed; left: 50%; bottom: 20px; transform: translateX(-50%);
        z-index: 10; color: #f6efe3cc; font: 12px/1.4 monospace;
        letter-spacing: 0.12em; text-transform: uppercase; pointer-events: none;
        text-shadow: 0 1px 8px #000; transition: opacity 400ms ease;
      }
    </style>
  </head>
  <body>
    <canvas id="stage" data-scene></canvas>
    <div id="placards"></div>
    <div id="hud">booting…</div>
    <div id="hint">drag the gaze · hover a world · click to enter</div>

    <script>
      import '@fontsource-variable/fraunces/full.css';
      import '@fontsource-variable/fraunces/full-italic.css';
      import { mountHub } from '../../scenes/hub';

      const params = new URLSearchParams(location.search);
      const fov = parseFloat(params.get('fov') ?? '55');
      const yaw = parseFloat(params.get('yaw') ?? '0.46');
      const doNav = params.has('nav');

      const canvas = document.getElementById('stage') as HTMLCanvasElement;
      const hud = document.getElementById('hud')!;
      const placards = document.getElementById('placards')!;
      const hint = document.getElementById('hint')!;

      // ── FPS meter, fed by the scene's per-frame callback ──
      let frames = 0, t0 = performance.now(), fps = 0;
      const onFrame = () => {
        frames++;
        const now = performance.now();
        if (now - t0 >= 500) {
          fps = Math.round((frames * 1000) / (now - t0));
          frames = 0; t0 = now;
          hud.textContent =
            `main-lobby spike\nFPS = ${fps}\nfov ${fov}  yaw ${yaw.toFixed(2)}\n` +
            `(?hour ?fov ?yaw ?nav)`;
          (window as any).__hubFps = fps;
        }
      };

      const hub = await mountHub(canvas, { fov, maxYaw: yaw, onFrame });
      if (!hub) { hud.textContent = 'no WebGPU'; throw new Error('no WebGPU'); }
      (window as any).__hub = hub; // verify/debug hook

      // ── build one placard per plate ──
      const els = new Map<string, HTMLElement>();
      for (const p of hub.plates) {
        const el = document.createElement('div');
        el.className = 'placard';
        el.dataset.id = p.id;
        el.innerHTML =
          `<div class="num">${p.numeral}</div>` +
          `<div class="name">${p.name}</div>` +
          `<div class="rule"></div>` +
          `<div class="line">${p.line}</div>`;
        placards.appendChild(el);
        els.set(p.id, el);
      }

      // ── position the placards each frame from the projected anchors ──
      hub.setOnUpdate((list) => {
        (window as any).__hubPlates = list; // verify/debug hook
        for (const s of list) {
          const el = els.get(s.id);
          if (!el) continue;
          if (!s.visible) { el.style.opacity = '0'; continue; }
          const sc = s.hovered ? Math.max(s.scale, 1.0) : s.scale;
          el.style.transform = `translate3d(${s.x.toFixed(1)}px, ${s.y.toFixed(1)}px, 0) translate(-50%, 0) scale(${sc.toFixed(3)})`;
          el.classList.toggle('is-hovered', s.hovered);
          // quiet but discoverable at rest; hover lifts to full via CSS
          if (!s.hovered) el.style.opacity = String(Math.min(0.55, 0.3 + s.scale * 0.22).toFixed(2));
        }
      });

      // ── click a plate → dolly through the frame → (optionally) navigate ──
      let entering = false;
      canvas.addEventListener('click', async () => {
        const id = hub.hoveredId();
        if (!id || entering) return;
        entering = true;
        hint.style.opacity = '0';
        await hub.focus(id);
        const href = hub.plates.find((p) => p.id === id)?.href;
        if (doNav && href) {
          location.href = href;
        } else {
          // spike: hold a beat, then ease back so we can keep testing
          hud.textContent = `→ would navigate to ${href}\n(add ?nav to follow the link)`;
          setTimeout(() => {
            hub.unfocus();
            entering = false;
            hint.style.opacity = '';
          }, 900);
        }
      });

      addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { hub.unfocus(); entering = false; hint.style.opacity = ''; }
      });
    </script>
  </body>
</html>
