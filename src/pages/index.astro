---
/**
 * Act 0 — The Summit. The frontispiece of the whole journey.
 * Full text lives in HTML (SEO); the living fog streams in on top.
 */
import World from '../layouts/World.astro';

const title = 'Mattis Engelhardt — Wanderer Between Worlds';
const description =
  'The personal world of Mattis Engelhardt: business student, AI builder, pilgrim. A walkable artwork in five acts — from a sea of fog to a city of agents.';
---

<World title={title} description={description} world="summit" withPerson>
  <!-- paint the sky to the visitor's clock before any JS framework wakes up -->
  <script is:inline>
    (() => {
      // ?hour=19.5 is the dev override for the whole daypart system
      const q = parseFloat(new URLSearchParams(location.search).get('hour') ?? '');
      const h = Number.isFinite(q) ? ((q % 24) + 24) % 24 : new Date().getHours();
      document.documentElement.dataset.daypart =
        h < 5 ? 'night' : h < 9 ? 'dawn' : h < 17 ? 'day' : h < 19 ? 'golden' : h < 22 ? 'dusk' : 'night';
    })();
  </script>

  <div class="descent-track" id="descent-track">
    <header class="hero" data-scene>
      <canvas id="summit-canvas" aria-hidden="true"></canvas>
      <div class="frontispiece">
        <p class="mono-label">Act 0 — The Summit</p>
        <h1>Mattis Engelhardt</h1>
        <p class="tagline lede">
          Building agents until all that&rsquo;s left to do is what I love.
        </p>
      </div>
      <a class="descend mono-label" href="#descent">
        <span>Descend into the fog</span>
        <span class="descend-line" aria-hidden="true"></span>
      </a>
      <!-- the white-out: scroll sinks the page into the sea of fog -->
      <div class="fog-veil" aria-hidden="true"></div>
    </header>
  </div>

  <section id="descent" class="paper" aria-label="About this place">
    <div class="act">
      <p class="mono-label">A wanderer between worlds</p>
      <h2>This is not a portfolio. It is a journey.</h2>
      <p>
        Mattis Engelhardt is a business student at Nürtingen-Geislingen
        University and a builder of AI agents. He walked the Camino de
        Santiago with his mother; now he walks the stranger path between
        painting and code, lecture hall and startup, pilgrim road and
        neon city.
      </p>
      <p>
        This site is that walk, told in five worlds. Each one is painted
        in a different style he loves — and each one is true.
      </p>
      <!-- TODO(content interview): bio facts, stations, what may be public -->
    </div>
  </section>

  <nav class="act worlds" aria-label="The five worlds">
    <p class="mono-label">The journey ahead</p>
    <ol>
      <li>
        <a href="/sea">
          <span class="numeral" aria-hidden="true">I</span>
          <span class="world-name">The Sea</span>
          <span class="world-line">who he is — a sunset ocean in oil paint</span>
        </a>
      </li>
      <li>
        <a href="/city">
          <span class="numeral" aria-hidden="true">II</span>
          <span class="world-name">The City of Agents</span>
          <span class="world-line">what he builds — a pixel night full of working machines</span>
        </a>
      </li>
      <li>
        <a href="/camino">
          <span class="numeral" aria-hidden="true">III</span>
          <span class="world-name">The Way</span>
          <span class="world-line">the human — real photographs along a pilgrim path</span>
        </a>
      </li>
      <li>
        <a href="/horizon">
          <span class="numeral" aria-hidden="true">IV</span>
          <span class="world-name">The Horizon</span>
          <span class="world-line">contact — above the clouds, the next world unwritten</span>
        </a>
      </li>
    </ol>
  </nav>

  <script>
    import { experienceMode, applyModeClass } from '../lib/quality';

    const mode = experienceMode();
    applyModeClass(mode);

    if (mode === 'full') {
      const { initJourney, gsap } = await import('../lib/journey');
      initJourney();

      let setDescent: (t: number) => void = () => {};
      const canvas = document.getElementById('summit-canvas');
      if (canvas instanceof HTMLCanvasElement) {
        const { mountSummit } = await import('../scenes/summit');
        const handle = await mountSummit(canvas);
        if (handle) setDescent = (t) => handle.setDescent(t);
      }

      /* the descent: one long scroll sinks the summit into the white-out.
         The veil ends on canvas-paper, exactly the colour of #descent —
         the journey resolves onto the page of a book. */
      const track = document.getElementById('descent-track');
      if (track) {
        const progress = { t: 0 };
        gsap
          .timeline({
            scrollTrigger: {
              trigger: track,
              start: 'top top',
              end: 'bottom bottom',
              scrub: 0.7,
            },
          })
          .to(progress, {
            t: 1,
            ease: 'none',
            duration: 1,
            onUpdate: () => setDescent(progress.t),
          }, 0)
          .to('.frontispiece', { yPercent: -46, autoAlpha: 0, ease: 'power1.in', duration: 0.55 }, 0)
          .to('.descend', { autoAlpha: 0, duration: 0.2 }, 0)
          .to('.fog-veil', { opacity: 1, ease: 'power1.inOut', duration: 0.62 }, 0.38);
      }

      /* narrative beats settle into place as the walk reaches them */
      for (const el of document.querySelectorAll('#descent .act > *, .worlds > *')) {
        gsap.from(el, {
          y: 28,
          autoAlpha: 0,
          duration: 0.9,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%' },
        });
      }
    }
  </script>
</World>

<style>
  /* the scroll runway for the descent — only the full experience
     gets the long sink; the catalogue reads straight through */
  :global([data-mode='full']) .descent-track {
    height: 280svh;
  }

  .hero {
    position: sticky;
    top: 0;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    /* the painted fallback sky — also the LCP backdrop while the scene streams in */
    background: linear-gradient(
      to bottom,
      #232a4a 0%,
      #5d4a6e 46%,
      #b85a3e 68%,
      #6e6286 100%
    );
  }

  :global([data-daypart='dawn']) .hero {
    background: linear-gradient(to bottom, #353c5e, #8a6d85 45%, #e89a5d 70%, #9aa7c4);
  }
  :global([data-daypart='day']) .hero {
    background: linear-gradient(to bottom, #7fa8d4, #a9c7e4 48%, #e9ddc6 72%, #c9d4e4);
  }
  :global([data-daypart='golden']) .hero {
    background: linear-gradient(to bottom, #4a5a86, #c97f4e 52%, #ffb45e 72%, #d9a87c);
  }
  :global([data-daypart='night']) .hero {
    background: linear-gradient(to bottom, #0b0e1d, #141a30 48%, #2a3552 72%, #232c44);
  }

  #summit-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity var(--t-setpiece) var(--ease-arrive);
  }

  .hero.is-live #summit-canvas {
    opacity: 1;
  }

  /* day skies are pale — the frontispiece switches to ink, like a
     printed plate caption (the scene behind stays painterly bright) */
  :global([data-daypart='day']) .hero {
    color: var(--c-deep);
  }
  :global([data-daypart='day']) .frontispiece h1 {
    text-shadow: 0 2px 44px rgb(246 239 227 / 0.5);
  }

  /* the white-out veil — ends exactly on the paper of #descent */
  .fog-veil {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    background:
      radial-gradient(120% 90% at 50% 110%, var(--c-canvas) 55%, color-mix(in oklab, var(--c-canvas) 92%, var(--c-babyblue)) 100%);
  }

  /* ── the paper interlude — the painting resolves into the book ── */
  .paper {
    position: relative;
    background: var(--c-canvas);
    color: var(--c-ink);
    color-scheme: light;
  }

  .paper :global(.mono-label) {
    color: var(--c-vermilion);
    opacity: 0.85;
  }

  .frontispiece {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--gutter);
    /* lifted above the fog floor */
    translate: 0 -6vh;
  }

  .frontispiece h1 {
    margin-block: 0.3em 0.35em;
    text-shadow: 0 2px 40px rgb(20 18 31 / 0.35);
  }

  .tagline {
    margin-inline: auto;
    opacity: 0.92;
  }

  .descend {
    position: absolute;
    z-index: 1;
    bottom: clamp(4.5rem, 9vh, 7rem);
    left: 50%;
    translate: -50% 0;
    display: grid;
    justify-items: center;
    gap: 0.75rem;
    text-decoration: none;
    opacity: 0.85;
  }

  .descend-line {
    width: 1px;
    height: 2.75rem;
    background: currentColor;
    animation: descend-breathe 2.8s var(--ease-journey) infinite;
    transform-origin: top;
  }

  @keyframes descend-breathe {
    0%, 100% { scale: 1 0.35; opacity: 0.4; }
    50% { scale: 1 1; opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .descend-line { animation: none; }
  }

  /* ── the five worlds ── */
  .worlds ol {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .worlds li + li {
    border-top: 1px solid color-mix(in oklab, var(--c-canvas) 14%, transparent);
  }

  .worlds a {
    display: grid;
    grid-template-columns: 3rem 1fr;
    grid-template-areas: 'numeral name' 'numeral line';
    align-items: baseline;
    padding: 1.5rem 0.5rem;
    text-decoration: none;
    transition: background var(--t-flick) var(--ease-lift);
  }

  .worlds a:hover {
    background: color-mix(in oklab, var(--c-canvas) 5%, transparent);
  }

  .worlds .numeral {
    grid-area: numeral;
    font-family: var(--font-mono);
    color: var(--c-sun);
    font-size: var(--text-small);
  }

  .world-name {
    grid-area: name;
    font-size: var(--text-lede);
    font-variation-settings: 'opsz' 60, 'SOFT' 0, 'WONK' 1;
  }

  .world-line {
    grid-area: line;
    opacity: 0.65;
    font-style: italic;
    font-size: var(--text-small);
    letter-spacing: 0.02em;
  }
</style>
