---
/**
 * Act 0 — The Summit. The frontispiece of the whole journey.
 * Full text lives in HTML (SEO); the living fog streams in on top.
 */
import World from '../layouts/World.astro';

const title = 'Mattis Engelhardt — Wanderer Between Worlds';
const description =
  'The personal world of Mattis Engelhardt: business student, AI builder, pilgrim. A walkable artwork in five acts — from a sea of fog to a city of agents.';
---

<World title={title} description={description} world="summit" withPerson>
  <!-- paint the sky to the visitor's clock before any JS framework wakes up.
       First-paint copy of src/lib/daypart.ts (die Passage re-applies it after
       every swap) — keep the two in sync. -->
  <script is:inline>
    (() => {
      // ?hour=19.5 is the dev override for the whole daypart system
      const q = parseFloat(new URLSearchParams(location.search).get('hour') ?? '');
      const h = Number.isFinite(q) ? ((q % 24) + 24) % 24 : new Date().getHours();
      document.documentElement.dataset.daypart =
        h < 5 ? 'night' : h < 9 ? 'dawn' : h < 17 ? 'day' : h < 19 ? 'golden' : h < 22 ? 'dusk' : 'night';
    })();
  </script>

  <!-- Act 0 opens at a museum wall: his favourite painting, framed.
       Scrolling pushes the camera through the canvas, landing in the left
       half (the sea of fog + the blue ridges), and dissolves seamlessly
       into the living Main-Lobby — the 3D world continues the painting
       (src/scenes/threshold.ts → src/scenes/hub.ts). In the catalogue this
       is simply the framed plate at the top of the page. -->
  <section class="threshold" id="threshold" aria-label="Through the frame — Wanderer above the Sea of Fog">
    <div class="gallery" aria-hidden="true"></div>
    <figure class="artframe">
      <div class="art-mat">
        <img
          class="art"
          src="/assets/paintings/wanderer_overview.webp"
          width="5256"
          height="6742"
          fetchpriority="high"
          decoding="async"
          alt="Wanderer above the Sea of Fog by Caspar David Friedrich: a man in a dark coat stands on a rocky summit, his back to us, gazing across a sea of fog toward distant mountains."
        />
      </div>
      <figcaption class="plate">
        <span class="plate-artist mono-label">Caspar David Friedrich</span>
        <span class="plate-title">Wanderer above the Sea of Fog</span>
        <span class="plate-meta mono-label">Oil on canvas · 1818 · the painting Mattis carries</span>
      </figcaption>
      <span class="threshold-cue mono-label" aria-hidden="true">Scroll to step inside</span>
    </figure>
  </section>

  <!-- the scroll runway for the push through the painting. Once it dissolves,
       you stand inside the living Main-Lobby (src/scenes/hub.ts): the sea of
       fog, the distant peaks, and the four worlds hanging in the air as
       gallery canvases — the 3D blocks ARE the navigation. -->
  <div class="threshold-track" id="threshold-track">
    <header class="hero" data-scene>
      <canvas id="hub-canvas" aria-hidden="true"></canvas>
      <!-- the gallery placards: one museum card per world, positioned per
           frame from the projected canvas anchor by the controller. The full
           experience reveals them in 3D; the catalogue uses the <ol> below. -->
      <div class="hub-placards" id="hub-placards" aria-hidden="true"></div>
      <!-- the only chrome in the lobby: a quiet affordance, fading in once you
           have stepped through the canvas. -->
      <p class="hub-cue mono-label" aria-hidden="true">
        Drag the gaze · hover a world · click to enter
      </p>
      <!-- the frontispiece title lives only in the catalogue / SEO path; in
           the full experience the lobby itself is the opening (no figure, no
           descent white-out). Kept in the DOM for the catalogue + screen
           readers; CSS hides it in full mode. -->
      <div class="frontispiece">
        <p class="mono-label">Act 0 — The Threshold</p>
        <h1>Mattis Engelhardt</h1>
        <p class="tagline lede">
          Building agents until all that&rsquo;s left to do is what I love.
        </p>
      </div>
    </header>
  </div>

  <section id="descent" class="paper" aria-label="About this place">
    <div class="act">
      <p class="mono-label">A wanderer between worlds</p>
      <h2>This is Mattis Engelhardt.</h2>
      <p>
        Mattis Engelhardt is a business student at Nürtingen-Geislingen
        University and a builder of AI agents. He walked the Camino de
        Santiago with his mother; now he walks the stranger path between
        painting and code, lecture hall and startup, pilgrim road and
        neon city.
      </p>
      <p>
        This site is that walk, told in five worlds. Each one is painted
        in a different style he loves — and each one is true.
      </p>
      <!-- TODO(content interview): bio facts, stations, what may be public -->
    </div>
  </section>

  <nav class="act worlds" aria-label="The five worlds">
    <p class="mono-label">The journey ahead</p>
    <ol>
      <li>
        <a href="/sea">
          <span class="numeral" aria-hidden="true">I</span>
          <span class="world-name">The Sea</span>
          <span class="world-line">Who he is.</span>
        </a>
      </li>
      <li>
        <a href="/city">
          <span class="numeral" aria-hidden="true">II</span>
          <span class="world-name">The City</span>
          <span class="world-line">What he builds.</span>
        </a>
      </li>
      <li>
        <a href="/camino">
          <span class="numeral" aria-hidden="true">III</span>
          <span class="world-name">The Way</span>
          <span class="world-line">Where he walked.</span>
        </a>
      </li>
      <li>
        <a href="/horizon">
          <span class="numeral" aria-hidden="true">IV</span>
          <span class="world-name">The Horizon</span>
          <span class="world-line">What's next.</span>
        </a>
      </li>
    </ol>
  </nav>

  <!-- runtime logic lives in src/worlds/summit.ts, mounted by die Passage -->
</World>

<style>
  /* the scroll runway — the full experience pushes through the painting,
     which dissolves into the living Main-Lobby (the hub stays pinned via
     .hero { position: sticky }). The catalogue reads straight through
     (threshold plate → name → about). */
  :global([data-mode='full']) .threshold-track {
    height: 300svh;
  }

  /* in the full experience the lobby IS the opening — the frontispiece
     title and the placard/cue chrome belong to the 3D scene, not the page.
     The catalogue keeps the frontispiece (its title + tagline). */
  :global([data-mode='full']) .frontispiece {
    display: none;
  }
  /* the catalogue (and reduced-motion / no-JS) never mounts the hub — hide
     its empty containers there so they leave no gap. */
  :global([data-mode='catalog']) .hub-placards,
  :global([data-mode='catalog']) .hub-cue {
    display: none;
  }

  /* ── the gallery placards (one museum card per world, positioned per
        frame by the controller from the projected canvas anchor) ── */
  .hub-placards {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }
  .hub-placards :global(.placard) {
    position: absolute;
    left: 0;
    top: 0;
    transform: translate3d(-50%, 0, 0);
    text-align: center;
    color: #f7f1e6;
    text-decoration: none;
    opacity: 0;
    transition: opacity 320ms var(--ease-lift), filter 320ms var(--ease-lift);
    will-change: transform, opacity;
    padding: 0.5em 1.1em 0.65em;
    border-radius: 2px;
    background: linear-gradient(180deg,
      color-mix(in oklab, #1a1422 78%, transparent),
      color-mix(in oklab, #1a1422 58%, transparent));
    box-shadow: 0 6px 26px rgba(8, 6, 12, 0.4);
    backdrop-filter: blur(3px);
    border-top: 1px solid color-mix(in oklab, #ffce86 40%, transparent);
    text-shadow: 0 1px 3px rgba(8, 6, 12, 0.85);
  }
  .hub-placards :global(.placard .num) {
    display: block;
    font: 600 11px/1 var(--font-mono);
    letter-spacing: 0.24em;
    color: #ffce86;
    opacity: 0.9;
  }
  .hub-placards :global(.placard .name) {
    display: block;
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-variation-settings: 'opsz' 72, 'SOFT' 0, 'WONK' 1;
    font-weight: 480;
    margin: 0.4em 0 0.15em;
    font-size: clamp(1.25rem, 2.6vw, 2.05rem);
    line-height: 1.05;
  }
  .hub-placards :global(.placard .rule) {
    display: block;
    width: 2.4em;
    height: 1px;
    margin: 0.5em auto;
    background: linear-gradient(90deg, transparent, #ffce86, transparent);
    opacity: 0.8;
  }
  .hub-placards :global(.placard .line) {
    display: block;
    font: italic 400 0.9rem/1.3 'Fraunces Variable', 'Fraunces', Georgia, serif;
    opacity: 0.9;
    letter-spacing: 0.01em;
  }
  .hub-placards :global(.placard.is-hovered) {
    opacity: 1 !important;
    background: linear-gradient(180deg,
      color-mix(in oklab, #1a1422 90%, transparent),
      color-mix(in oklab, #1a1422 72%, transparent));
  }

  /* the one quiet affordance in the lobby */
  .hub-cue {
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 4vh, 3rem);
    transform: translateX(-50%);
    z-index: 4;
    color: #f6efe3cc;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    pointer-events: none;
    text-shadow: 0 1px 8px #000;
    text-align: center;
  }

  /* the painted fallback sky — also the LCP backdrop while the scene streams in */
  .hero {
    background: linear-gradient(
      to bottom,
      #232a4a 0%,
      #5d4a6e 46%,
      #b85a3e 68%,
      #6e6286 100%
    );
  }

  :global([data-daypart='dawn']) .hero {
    background: linear-gradient(to bottom, #353c5e, #8a6d85 45%, #e89a5d 70%, #9aa7c4);
  }
  :global([data-daypart='day']) .hero {
    background: linear-gradient(to bottom, #7fa8d4, #a9c7e4 48%, #e9ddc6 72%, #c9d4e4);
  }
  :global([data-daypart='golden']) .hero {
    background: linear-gradient(to bottom, #4a5a86, #c97f4e 52%, #ffb45e 72%, #d9a87c);
  }
  :global([data-daypart='night']) .hero {
    background: linear-gradient(to bottom, #0b0e1d, #141a30 48%, #2a3552 72%, #232c44);
  }

  /* day skies are pale — the catalogue frontispiece switches to ink, like a
     printed plate caption (the lobby scene behind stays painterly bright) */
  :global([data-daypart='day']) .hero {
    color: var(--c-deep);
  }
  :global([data-daypart='day']) .frontispiece h1 {
    text-shadow: 0 2px 44px rgb(246 239 227 / 0.5);
  }

  /* ── the five worlds ── */
  .worlds ol {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .worlds li + li {
    border-top: 1px solid color-mix(in oklab, var(--c-canvas) 14%, transparent);
  }

  .worlds a {
    display: grid;
    grid-template-columns: 3rem 1fr;
    grid-template-areas: 'numeral name' 'numeral line';
    align-items: baseline;
    padding: 1.5rem 0.5rem;
    text-decoration: none;
    transition: background var(--t-flick) var(--ease-lift);
  }

  .worlds a:hover {
    background: color-mix(in oklab, var(--c-canvas) 5%, transparent);
  }

  .worlds .numeral {
    grid-area: numeral;
    font-family: var(--font-mono);
    color: var(--c-sun);
    font-size: var(--text-small);
  }

  .world-name {
    grid-area: name;
    font-size: var(--text-lede);
    font-variation-settings: 'opsz' 60, 'SOFT' 0, 'WONK' 1;
  }

  .world-line {
    grid-area: line;
    opacity: 0.65;
    font-style: italic;
    font-size: var(--text-small);
    letter-spacing: 0.02em;
  }
</style>
