---
/**
 * World.astro — the frame every world hangs in.
 * Full semantic HTML + SEO per route; heavy scenes mount as lazy islands.
 */
// 'full' variant = all variable axes (opsz, wght, SOFT, WONK) — our
// typography leans on them at display sizes.
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import PathNav from '../components/PathNav.astro';

export interface Props {
  title: string;
  description: string;
  world: 'summit' | 'sea' | 'city' | 'camino' | 'horizon';
  /** include the schema.org Person graph (home only) */
  withPerson?: boolean;
}

const { title, description, world, withPerson = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

// TODO(Mattis): confirm sameAs links (GitHub, LinkedIn) in the content interview.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mattis Engelhardt',
  url: Astro.site?.toString(),
  description:
    'Business student and AI builder. Building agents until all that is left to do is what he loves.',
  knowsAbout: ['AI Agents', 'Business Administration', 'Web Experiences'],
  affiliation: {
    '@type': 'CollegeOrUniversity',
    name: 'Nürtingen-Geislingen University (HfWU)',
  },
};
---

<!doctype html>
<html lang="en" data-world={world}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#14121f" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mattis Engelhardt — Der Wanderer" />
    <meta name="twitter:card" content="summary_large_image" />

    {
      withPerson && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personSchema)}
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main">
      <slot />
    </main>
    <PathNav current={world} />
  </body>
</html>
