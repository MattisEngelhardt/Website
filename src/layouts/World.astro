---
/**
 * World.astro — the frame every world hangs in.
 * Full semantic HTML + SEO per route; heavy scenes mount as lazy islands.
 */
// 'full' variant = all variable axes (opsz, wght, SOFT, WONK) — our
// typography leans on them at display sizes.
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
// the signature loader's hand — an elegant script for "Mattis E."
import '@fontsource/allura/400.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import PathNav from '../components/PathNav.astro';

export interface Props {
  title: string;
  description: string;
  world: 'summit' | 'sea' | 'city' | 'camino' | 'horizon';
  /** include the schema.org Person graph (home only) */
  withPerson?: boolean;
}

const { title, description, world, withPerson = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

// TODO(Mattis): confirm sameAs links (GitHub, LinkedIn) in the content interview.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mattis Engelhardt',
  url: Astro.site?.toString(),
  description:
    'Business student and AI builder. Building agents until all that is left to do is what he loves.',
  knowsAbout: ['AI Agents', 'Business Administration', 'Web Experiences'],
  affiliation: {
    '@type': 'CollegeOrUniversity',
    name: 'Nürtingen-Geislingen University (HfWU)',
  },
};
---

<!doctype html>
<!-- die Passage drives all transition theatre — the router's own crossfade stays out of the way -->
<html lang="en" data-world={world} transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#14121f" />

    <!-- arm the signature loader before first paint: only the first
         visit of a session, never reduced-motion / save-data / no-JS.
         CSS keeps the loader hidden unless <html data-loading>. -->
    <script is:inline>
      (() => {
        try {
          const rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
          const conn = navigator.connection;
          const seen = sessionStorage.getItem('seen-signature');
          if (!rm && !(conn && conn.saveData) && !seen) {
            document.documentElement.dataset.loading = '1';
            // failsafe: never trap the visitor if the module never runs
            setTimeout(() => document.documentElement.removeAttribute('data-loading'), 6000);
          }
        } catch (e) {
          /* no storage / matchMedia — just skip the loader */
        }
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mattis Engelhardt — Der Wanderer" />
    <meta name="twitter:card" content="summary_large_image" />

    {
      withPerson && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personSchema)}
        />
      )
    }

    <ClientRouter fallback="swap" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main">
      <slot />
    </main>
    <PathNav current={world} />

    <!-- die Passage: the painted veil between worlds. Persisted so a
         mid-sweep stroke survives the document swap underneath it. -->
    <div
      class="passage"
      id="passage"
      data-state="idle"
      aria-hidden="true"
      transition:persist="passage"
    >
      <div class="passage-stroke s1"></div>
      <div class="passage-stroke s2"></div>
      <div class="passage-stroke s3"></div>
      <div class="passage-plate">
        <span class="passage-act mono-label"></span>
        <span class="passage-name"></span>
      </div>
    </div>

    <!-- The signature loader: "Mattis E.", written by hand. Persisted
         so it survives the first swap; armed only on first visit. -->
    <div
      class="signature-loader"
      id="signature-loader"
      aria-hidden="true"
      transition:persist="signature"
    >
      <div class="sig">
        <span class="sig-word">Mattis E.</span>
        <svg
          class="sig-flourish-svg"
          viewBox="0 0 1000 360"
          fill="none"
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
        >
          <path
            class="sig-flourish"
            pathLength="1"
            d="M 690 214 C 654 286 470 318 300 312 C 196 308 150 296 150 276 C 150 262 168 256 196 264"
          ></path>
        </svg>
      </div>
    </div>

    <script>
      import { initPassage } from '../lib/passage';
      import { playSignature } from '../lib/signature';
      void playSignature();
      initPassage();
    </script>
  </body>
</html>
